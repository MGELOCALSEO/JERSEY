{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm ci",
  "rewrites": [
    { "source": "/club", "destination": "/club.html" },
    { "source": "/national", "destination": "/national.html" },
    { "source": "/retro", "destination": "/retro.html" },
    { "source": "/kids", "destination": "/kids.html" },
    { "source": "/product/:slug", "destination": "/index.html" },
    { "source": "/category/:cat", "destination": "/index.html" },
    { "source": "/chelsea-jersey-lagos", "destination": "/index.html" },
    { "source": "/manchester-united-jersey-lagos", "destination": "/index.html" },
    { "source": "/arsenal-jersey-lagos", "destination": "/index.html" },
    { "source": "/barcelona-jersey-lagos", "destination": "/index.html" },
    { "source": "/real-madrid-jersey-lagos", "destination": "/index.html" },
    { "source": "/retro-football-jerseys", "destination": "/index.html" },
    { "source": "/custom-football-jerseys", "destination": "/index.html" },
    { "source": "/football-jerseys-lekki-lagos", "destination": "/index.html" },
    { "source": "/football-jerseys-ikeja-lagos", "destination": "/index.html" },
    { "source": "/football-jerseys-surulere-lagos", "destination": "/index.html" },
    { "source": "/football-jerseys-abuja", "destination": "/index.html" },
    { "source": "/football-jerseys-port-harcourt", "destination": "/index.html" },
    { "source": "/football-jerseys-ibadan", "destination": "/index.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
